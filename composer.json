{
  "name": "egorbaklach/microbe",
  "type": "project",
  "description": "Microbe",
  "license": "MIT",
  "require": {
    "php": "^7.3.0",
    "league/container": "3.3.4",
    "league/plates": "3.3.0",
    "league/route": "5.0.0",
    "laminas/laminas-diactoros": "2.5.0",
    "laminas/laminas-httphandlerrunner": "1.3.0",
    "laminas/laminas-config-aggregator": "1.4.0",
    "phpfastcache/phpfastcache": "8.0.4",
    "egorbaklach/contracts": "1.0",
    "egorbaklach/molecule": "1.0",
    "ext-pdo": "*"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/App",
      "Framework\\": "src/Framework",
      "Infrastructure\\": "src/Infrastructure"
    }
  },
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true
  },
  "minimum-stability": "dev"
}